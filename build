#!/data/data/com.termux/files/usr/bin/bash
# SPDX-License-Identifier: MIT
#
# build — Build and install ovgl v0.2.0
#
# Usage:
#   ./build              Build and install
#   ./build -c           Clean reinstall (remove old, rebuild)
#   ./build --clean      Same as -c
#
set -eu

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PREFIX="${PREFIX:-/data/data/com.termux/files/usr}"
GLIBC_PREFIX="$PREFIX/glibc"
RELEASE_URL="https://github.com/theonuverse/ovgl/releases/download/v0.2.0"

X86_LIB_DIR="$GLIBC_PREFIX/lib/x86_64-linux-gnu"
BOX64_DEST="$PREFIX/bin/box64"
PRELOAD_DEST="$GLIBC_PREFIX/lib/libovgl_preload.so"
OVGL_DEST="$PREFIX/bin/ovgl"

# ── colours ──────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

info()  { printf "${GREEN}[INFO]${NC} %s\n" "$*"; }
ok()    { printf "${GREEN}[ OK ]${NC} %s\n" "$*"; }
warn()  { printf "${YELLOW}[WARN]${NC} %s\n" "$*"; }
die()   { printf "${RED}[ERROR]${NC} %s\n" "$*" >&2; exit 1; }

# ── clean ────────────────────────────────────────────────────────────
do_clean() {
    info "Cleaning old installation..."
    rm -f  "$OVGL_DEST"                         2>/dev/null || true
    rm -f  "$PRELOAD_DEST"                      2>/dev/null || true
    rm -f  "$GLIBC_PREFIX/bin/box64"            2>/dev/null || true
    rm -f  "$BOX64_DEST"                        2>/dev/null || true
    rm -rf "$GLIBC_PREFIX/lib_x86_64"           2>/dev/null || true
    rm -rf "$X86_LIB_DIR"                       2>/dev/null || true
    rm -f  ovgl libovgl_preload.so preload_data.h 2>/dev/null || true
    ok "Clean complete"
}

# ── libc.so symlink fix ─────────────────────────────────────────────
fix_libc_symlink() {
    local lib="$GLIBC_PREFIX/lib"
    if [ -f "$lib/libc.so" ] && [ ! -L "$lib/libc.so" ]; then
        info "Fixing libc.so → libc.so.6 symlink"
        mv "$lib/libc.so" "$lib/libc.so.script" || warn "Could not move libc.so"
    fi
    if [ ! -L "$lib/libc.so" ] && [ -f "$lib/libc.so.6" ]; then
        ln -sf libc.so.6 "$lib/libc.so" || warn "Could not create libc.so symlink"
    fi
}

# ── parse args ───────────────────────────────────────────────────────
cd "$SCRIPT_DIR"

if [ "${1:-}" = "-c" ] || [ "${1:-}" = "--clean" ] || [ "${1:-}" = "--clean-reinstall" ]; then
    do_clean
fi

# ── prerequisites ────────────────────────────────────────────────────
command -v clang  >/dev/null 2>&1 || die "clang not found.  Run: pkg install clang"
command -v curl   >/dev/null 2>&1 || die "curl not found.   Run: pkg install curl"
[ -d "$GLIBC_PREFIX" ]           || die "glibc not found.  Run: pkg install glibc-repo && pkg install glibc"

fix_libc_symlink

# ── step 0: x86_64 libraries ────────────────────────────────────────
info "Step 0: x86_64 libraries"

if [ -d "$X86_LIB_DIR" ] && [ -n "$(ls -A "$X86_LIB_DIR" 2>/dev/null)" ]; then
    info "Already present — skipping"
else
    info "Downloading from $RELEASE_URL/lib_x86_64.tar.gz ..."
    tmpdir="$(mktemp -d)"
    trap 'rm -rf "$tmpdir"' EXIT

    curl -fSL --progress-bar -o "$tmpdir/lib_x86_64.tar.gz" \
        "$RELEASE_URL/lib_x86_64.tar.gz" \
        || die "Download failed"

    mkdir -p "$X86_LIB_DIR"
    tar xzf "$tmpdir/lib_x86_64.tar.gz" --strip-components=1 -C "$X86_LIB_DIR" \
        || die "Extraction failed"

    rm -rf "$tmpdir"
    trap - EXIT
    ok "Installed x86_64 libs → $X86_LIB_DIR"
fi

# ── step 0b: box64 ──────────────────────────────────────────────────
info "Checking box64..."

if [ -x "$BOX64_DEST" ]; then
    info "Already present — skipping"
else
    info "Downloading from $RELEASE_URL/box64 ..."
    curl -fSL --progress-bar -o "$BOX64_DEST" "$RELEASE_URL/box64" \
        || die "Download failed"
    chmod 755 "$BOX64_DEST"
    ok "Installed box64 → $BOX64_DEST"
fi

mkdir -p "$GLIBC_PREFIX/bin"

# ── step 1: preload library (glibc sysroot) ─────────────────────────
info "Step 1: Building preload library..."

LD_PRELOAD="" clang \
    --sysroot="$GLIBC_PREFIX" \
    -shared -fPIC -O2 \
    -Wall -Wextra -Wpedantic \
    --target=aarch64-linux-gnu \
    -I"$GLIBC_PREFIX/include" \
    -L"$GLIBC_PREFIX/lib" \
    -Wl,--dynamic-linker="$GLIBC_PREFIX/lib/ld-linux-aarch64.so.1" \
    -Wl,-rpath,"$GLIBC_PREFIX/lib" \
    -Wl,--no-as-needed \
    -o libovgl_preload.so \
    ovgl_preload.c \
    -lc -ldl \
    || die "Failed to build libovgl_preload.so"

ok "Built libovgl_preload.so ($(wc -c < libovgl_preload.so) bytes)"

# ── step 2: embedded preload header ─────────────────────────────────
info "Step 2: Generating preload_data.h..."

{
    echo "/* Auto-generated — do not edit */"
    echo "static const unsigned char preload_so_data[] = {"
    od -An -tx1 -v libovgl_preload.so \
        | sed 's/[0-9a-f]\{2\}/0x&,/g; s/  */ /g; s/^/    /'
    echo "};"
    echo "static const unsigned int preload_so_size = sizeof(preload_so_data);"
} > preload_data.h

ok "Generated preload_data.h ($(wc -l < preload_data.h) lines)"

# ── step 3: ovgl binary (bionic) ────────────────────────────────────
info "Step 3: Building ovgl..."

clang \
    -O2 -Wall -Wextra -Wpedantic \
    -DEMBED_PRELOAD \
    -o ovgl \
    ovgl.c \
    || die "Failed to build ovgl"

ok "Built ovgl ($(wc -c < ovgl) bytes)"

# ── step 4: verify ──────────────────────────────────────────────────
info "Step 4: Verifying..."

printf "\n${BLUE}libovgl_preload.so:${NC}\n"
file libovgl_preload.so

printf "\n${BLUE}ovgl:${NC}\n"
file ovgl

# ── step 5: install ─────────────────────────────────────────────────
info "Step 5: Installing..."

install -m 755 libovgl_preload.so "$PRELOAD_DEST" \
    || die "Failed to install preload library"

if ! install -m 755 ovgl "$OVGL_DEST" 2>/dev/null; then
    warn "Binary busy — atomic replace..."
    tmpbin="$(mktemp "$OVGL_DEST.XXXXXX")"
    cp ovgl "$tmpbin"
    chmod 755 "$tmpbin"
    mv -f "$tmpbin" "$OVGL_DEST" \
        || die "Failed to install ovgl (still running?)"
fi

ok "Installed ovgl        → $OVGL_DEST"
ok "Installed preload     → $PRELOAD_DEST"
ok "x86_64 libs           → $X86_LIB_DIR"
ok "box64                 → $BOX64_DEST"

printf "\n${GREEN}════════════════════════════════════════${NC}\n"
printf "${GREEN}  ovgl v0.2.0 installed successfully${NC}\n"
printf "${GREEN}════════════════════════════════════════${NC}\n\n"
printf "  ovgl <binary> [args...]     Run a binary\n"
printf "  ovgl -d <binary>            Debug mode\n"
printf "  ovgl --version              Version info\n\n"
